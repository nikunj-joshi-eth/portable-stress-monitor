<div class="timestamp" id="timestamp">--:--:--</div>

<script>
const socket = io();

// ── ECG Setup ─────────────────────────────────────────
const ecgCanvas  = document.getElementById('ecg');
const ctx        = ecgCanvas.getContext('2d');
const aEcgCanvas = document.getElementById('ambientEcg');
const aCtx       = aEcgCanvas.getContext('2d');
const ECG_HIST   = 400;
let ecgData      = new Array(ECG_HIST).fill(0);
let writeHead    = 0, canvasW = 0, canvasH = 0;

function resizeCanvas() {
  canvasW = ecgCanvas.offsetWidth; canvasH = ecgCanvas.offsetHeight;
  ecgCanvas.width = canvasW; ecgCanvas.height = canvasH;
  aEcgCanvas.width  = aEcgCanvas.offsetWidth;
  aEcgCanvas.height = aEcgCanvas.offsetHeight;
}
resizeCanvas(); window.addEventListener('resize', resizeCanvas);

const PQRST = [0,0,0,0,0,0.08,0.15,0.20,0.15,0.08,0,0,0,0,-0.10,-0.20,0.50,0.85,1.00,0.85,0.50,-0.25,-0.15,0,0,0,0.08,0.18,0.28,0.30,0.28,0.18,0.08,0,0,0,0,0,0,0,0];
const PQRST_LEN = PQRST.length;
let pqrstIndex = 0, currentBPM = 0, lastECGTime = performance.now();

function generateECG(now) {
  const dt = now - lastECGTime; lastECGTime = now;
  if (currentBPM <= 0) { ecgData[writeHead]=0; writeHead=(writeHead+1)%ECG_HIST; return; }
  const step = dt / ((60000/currentBPM)/PQRST_LEN);
  ecgData[writeHead] = PQRST[Math.floor(pqrstIndex) % PQRST_LEN];
  writeHead = (writeHead+1) % ECG_HIST;
  pqrstIndex += step;
  if (pqrstIndex >= PQRST_LEN) pqrstIndex -= PQRST_LEN;
}

// ECG color smoothly interpolates green→amber→red with stress
function getECGColor() {
  return getComputedStyle(document.documentElement).getPropertyValue('--ecg-color').trim() || '#00ff88';
}

function drawECGOnCanvas(canvas, context, glow) {
  const w = canvas.width, h = canvas.height;
  context.clearRect(0,0,w,h);
  const mid = h/2, amp = h*0.38, xStep = w/ECG_HIST;
  const col = getECGColor();
  context.shadowColor = col; context.shadowBlur = glow ? 16 : 8;
  context.beginPath(); context.strokeStyle = col; context.lineWidth = glow ? 2.5 : 1.5; context.lineJoin = 'round';
  for (let i=0;i<ECG_HIST;i++) {
    const b=(writeHead+i)%ECG_HIST, x=i*xStep, y=mid-ecgData[b]*amp;
    if(i===0) context.moveTo(x,y); else context.lineTo(x,y);
  }
  context.stroke(); context.shadowBlur=0;
  if (!glow) document.getElementById('sweep').style.left=(writeHead/ECG_HIST*100)+'%';
}

// ── Particles ────────────────────────────────────────
const pCanvas = document.getElementById('particleCanvas');
const pCtx    = pCanvas.getContext('2d');
let particles = [];

function initParticles() {
  pCanvas.width  = window.innerWidth;
  pCanvas.height = window.innerHeight;
  particles = Array.from({length:60}, ()=>({
    x: Math.random()*pCanvas.width,
    y: Math.random()*pCanvas.height,
    r: Math.random()*2+0.5,
    dx: (Math.random()-.5)*0.4,
    dy: (Math.random()-.5)*0.4,
    alpha: Math.random()*0.5+0.1
  }));
}
initParticles();
window.addEventListener('resize', ()=>{ initParticles(); resizeCanvas(); });

function drawParticles() {
  pCtx.clearRect(0,0,pCanvas.width,pCanvas.height);
  const col = getECGColor();
  const speed = currentBPM > 0 ? (currentBPM / 70) : 1;
  particles.forEach(p => {
    p.x += p.dx * speed; p.y += p.dy * speed;
    if(p.x<0) p.x=pCanvas.width; if(p.x>pCanvas.width) p.x=0;
    if(p.y<0) p.y=pCanvas.height; if(p.y>pCanvas.height) p.y=0;
    pCtx.beginPath();
    pCtx.arc(p.x,p.y,p.r,0,Math.PI*2);
    pCtx.fillStyle = col + Math.floor(p.alpha*255).toString(16).padStart(2,'0');
    pCtx.fill();
  });
}

// ── Render loop ───────────────────────────────────────
function render(now) {
  generateECG(now);
  drawECGOnCanvas(ecgCanvas, ctx, false);
  if (document.getElementById('ambientOverlay').classList.contains('active'))
    drawECGOnCanvas(aEcgCanvas, aCtx, true);
  drawParticles();
  requestAnimationFrame(render);
}
requestAnimationFrame(render);

// ── Ripple on heartbeat ───────────────────────────────
let lastRippleTime = 0;
function triggerRipple() {
  const now = Date.now();
  if (currentBPM <= 0 || now - lastRippleTime < (60000/currentBPM)*0.8) return;
  lastRippleTime = now;
  const heart = document.getElementById('heartIcon');
  const rect  = heart.getBoundingClientRect();
  const cx = rect.left + rect.width/2, cy = rect.top + rect.height/2;
  const size = 40;
  const r = document.createElement('div');
  r.className = 'ripple';
  r.style.cssText = `left:${cx}px;top:${cy}px;width:${size}px;height:${size}px;`;
  document.body.appendChild(r);
  setTimeout(()=>r.remove(), 1000);
  // Heartbeat animation
  const h = document.getElementById('heartIcon');
  h.style.animation='none';
  requestAnimationFrame(()=>requestAnimationFrame(()=>{ h.style.animation='heartbeat 0.6s ease'; }));
}
setInterval(()=>{ if(currentBPM>0) triggerRipple(); }, 300);

// ── Sound mode ────────────────────────────────────────
let soundOn = false;
let lastBeepTime = 0;
let audioCtx = null;

function playBeep() {
  if (!soundOn || currentBPM <= 0) return;
  const now = Date.now();
  const interval = 60000 / currentBPM;
  if (now - lastBeepTime < interval * 0.85) return;
  lastBeepTime = now;
  try {
    if (!audioCtx) audioCtx = new (window.AudioContext||window.webkitAudioContext)();
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain); gain.connect(audioCtx.destination);
    osc.type='sine'; osc.frequency.value=660;
    gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime+0.08);
    osc.start(); osc.stop(audioCtx.currentTime+0.08);
  } catch(e){}
}
setInterval(playBeep, 200);

document.getElementById('soundBtn').addEventListener('click',()=>{
  soundOn = !soundOn;
  document.getElementById('soundBtn').textContent = soundOn ? '♪ SOUND ON' : '♪ SOUND OFF';
  document.getElementById('soundBtn').classList.toggle('active', soundOn);
  showToast(soundOn ? 'HEARTBEAT SOUND ON' : 'HEARTBEAT SOUND OFF');
});

// ── Sparkline ─────────────────────────────────────────
const sparkCanvas = document.getElementById('sparkCanvas');
const sCtx = sparkCanvas.getContext('2d');
const sparkData = [];
function drawSparkline() {
  const w=sparkCanvas.width, h=sparkCanvas.height;
  sCtx.clearRect(0,0,w,h);
  if(sparkData.length<2) return;
  const min=Math.max(40,Math.min(...sparkData)-5), max=Math.min(180,Math.max(...sparkData)+5);
  const xStep=w/(30-1), col=getECGColor();
  sCtx.strokeStyle=col; sCtx.lineWidth=1.5; sCtx.lineJoin='round'; sCtx.shadowColor=col; sCtx.shadowBlur=4;
  sCtx.beginPath();
  sparkData.forEach((v,i)=>{ const x=i*xStep, y=h-((v-min)/(max-min||1))*(h-4)-2; if(i===0)sCtx.moveTo(x,y);else sCtx.lineTo(x,y); });
  sCtx.stroke(); sCtx.shadowBlur=0;
}

// ── Animated counter ─────────────────────────────────
function animateValue(el, from, to, dur=400) {
  if(from===to) return;
  const start=performance.now();
  function step(now){ const t=Math.min((now-start)/dur,1), e=t<.5?2*t*t:-1+(4-2*t)*t; el.textContent=Math.round(from+(to-from)*e); if(t<1) requestAnimationFrame(step); }
  requestAnimationFrame(step);
}

// ── HRV Estimate ──────────────────────────────────────
// Estimates RMSSD from BPM variance — simplified but realistic looking
const bpmWindow = [];
function estimateHRV(bpm) {
  if (bpm <= 0) return 0;
  bpmWindow.push(bpm);
  if (bpmWindow.length > 20) bpmWindow.shift();
  if (bpmWindow.length < 2) return 0;
  // Convert BPM to RR intervals (ms), compute RMSSD
  const rr = bpmWindow.map(b => 60000/b);
  let sumSq = 0;
  for (let i=1;i<rr.length;i++) { const d=rr[i]-rr[i-1]; sumSq+=d*d; }
  return Math.round(Math.sqrt(sumSq/(rr.length-1)));
}

function updateHRVGauge(hrv) {
  const el = document.getElementById('hrvVal');
  const arc = document.getElementById('hrvArc');
  const desc = document.getElementById('hrvDesc');
  el.textContent = hrv > 0 ? hrv : '--';
  // HRV 0-100ms mapped to arc (126px circumference)
  const pct = Math.min(hrv/100, 1);
  arc.setAttribute('stroke-dashoffset', 126 - pct*126);
  // Color + description
  let color, text;
  if (hrv <= 0)      { color='#4a6a4a'; text='Awaiting data...'; }
  else if (hrv < 20) { color='#ff3355'; text='Very low — high stress'; }
  else if (hrv < 40) { color='#ffaa00'; text='Low — elevated stress'; }
  else if (hrv < 70) { color='#00ff88'; text='Normal — relaxed'; }
  else               { color='#00aaff'; text='High — very calm'; }
  arc.setAttribute('stroke', color);
  el.style.color = color;
  desc.textContent = text;
}

// ── Stress trend prediction ───────────────────────────
const stressHistory10s = [];
const stressNums = {'NO DATA':0,'LOW':1,'NORMAL':2,'MODERATE':3,'HIGH':4};

function updateTrend(stress) {
  stressHistory10s.push(stressNums[stress]||0);
  if (stressHistory10s.length > 10) stressHistory10s.shift();
  if (stressHistory10s.length < 3) return;
  const recent  = stressHistory10s.slice(-3).reduce((a,b)=>a+b,0)/3;
  const earlier = stressHistory10s.slice(0,3).reduce((a,b)=>a+b,0)/3;
  const diff = recent - earlier;
  const arrow = document.getElementById('trendArrow');
  const label = document.getElementById('trendLabel');
  if (diff > 0.5)       { arrow.textContent='↑'; arrow.style.color='#ff3355'; label.textContent='RISING'; }
  else if (diff < -0.5) { arrow.textContent='↓'; arrow.style.color='#00ff88'; label.textContent='FALLING'; }
  else                  { arrow.textContent='→'; arrow.style.color='#ffaa00'; label.textContent='STABLE'; }
}

// ── Heatmap ───────────────────────────────────────────
const HEATMAP_COLS = 64;
const heatmapData  = [];
const heatColors   = ['#1a2a1a','#0066cc','#00884a','#cc8800','#cc1133'];

function initHeatmap() {
  const grid = document.getElementById('heatmapGrid');
  grid.innerHTML = '';
  for (let i=0;i<HEATMAP_COLS;i++) {
    const cell = document.createElement('div');
    cell.className = 'heatmap-cell';
    cell.id = 'hm'+i;
    grid.appendChild(cell);
  }
}
initHeatmap();

function pushHeatmap(stress) {
  heatmapData.push(stressNums[stress]||0);
  if (heatmapData.length > HEATMAP_COLS) heatmapData.shift();
  // Render from right (newest = rightmost)
  const offset = HEATMAP_COLS - heatmapData.length;
  for (let i=0;i<HEATMAP_COLS;i++) {
    const cell = document.getElementById('hm'+i);
    if (!cell) continue;
    const dataIdx = i - offset;
    if (dataIdx < 0) { cell.style.background='#1a2a1a'; cell.removeAttribute('data-tip'); }
    else {
      const val = heatmapData[dataIdx];
      cell.style.background = heatColors[val];
      const labels = ['NONE','LOW','NORMAL','MODERATE','HIGH'];
      cell.setAttribute('data-tip', labels[val]);
    }
  }
}
setInterval(()=>{ pushHeatmap(lastStress||'NO DATA'); }, 5000);

// ── Charts ────────────────────────────────────────────
const MAX_H=60, hLabels=[], hData=[], sLabels=[], sData=[];
const hCtx  = document.getElementById('historyChart').getContext('2d');
const ssCtx = document.getElementById('stressChart').getContext('2d');
const chartDefaults = {
  responsive:true, maintainAspectRatio:false, animation:{duration:200},
  plugins:{legend:{display:false},tooltip:{backgroundColor:'#0d1318',borderColor:'#1a2a1a',borderWidth:1,titleColor:'#00ff88',bodyColor:'#c8e6c8',titleFont:{family:'Share Tech Mono'},bodyFont:{family:'Share Tech Mono'}}},
  scales:{x:{ticks:{color:'#4a6a4a',font:{family:'Share Tech Mono',size:9},maxTicksLimit:6},grid:{color:'#1a2a1a'},border:{color:'#1a2a1a'}},y:{ticks:{color:'#4a6a4a',font:{family:'Share Tech Mono',size:9}},grid:{color:'#1a2a1a'},border:{color:'#1a2a1a'}}}
};
const histChart = new Chart(hCtx, {type:'line',data:{labels:hLabels,datasets:[{label:'BPM',data:hData,borderColor:'#00ff88',backgroundColor:'rgba(0,255,136,0.06)',borderWidth:1.5,pointRadius:0,tension:.4,fill:true}]},options:{...chartDefaults,scales:{...chartDefaults.scales,y:{...chartDefaults.scales.y,min:40,max:180,ticks:{...chartDefaults.scales.y.ticks,stepSize:20}}}}});
const stressChart = new Chart(ssCtx, {type:'line',data:{labels:sLabels,datasets:[{label:'Stress',data:sData,borderColor:'#ffaa00',backgroundColor:'rgba(255,170,0,0.07)',borderWidth:1.5,pointRadius:0,tension:.3,fill:true}]},options:{...chartDefaults,scales:{...chartDefaults.scales,y:{...chartDefaults.scales.y,min:0,max:4,ticks:{...chartDefaults.scales.y.ticks,stepSize:1,callback:v=>['NONE','LOW','NRM','MOD','HIGH'][v]||''}}},plugins:{...chartDefaults.plugins,tooltip:{...chartDefaults.plugins.tooltip,callbacks:{label:c=>['NO DATA','LOW','NORMAL','MODERATE','HIGH'][c.raw]||c.raw}}}}});

function pushCharts(bpm, stress) {
  const lbl = new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  if (bpm > 0) {
    hLabels.push(lbl); hData.push(bpm);
    if (hLabels.length>MAX_H){hLabels.shift();hData.shift();}
    histChart.update();
    sparkData.push(bpm); if(sparkData.length>30)sparkData.shift(); drawSparkline();
  }
  if (stress && stress!=='NO DATA') {
    sLabels.push(lbl); sData.push(stressNums[stress]||0);
    if (sLabels.length>MAX_H){sLabels.shift();sData.shift();}
    stressChart.update();
  }
}

// ── Session stats ─────────────────────────────────────
let peakBPM=0, minBPM=999, bpmHist=[], prevBPM=0;

function updateStats(bpm) {
  if(bpm<=0) return;
  if(bpm>peakBPM){peakBPM=bpm; document.getElementById('peakBpm').textContent=peakBPM;}
  if(bpm<minBPM){minBPM=bpm; document.getElementById('minBpm').textContent=minBPM;}
  bpmHist.push(bpm); if(bpmHist.length>120)bpmHist.shift();
  document.getElementById('avgBpm').textContent=Math.round(bpmHist.reduce((a,b)=>a+b)/bpmHist.length);
}

// ── Session Report Card ───────────────────────────────
function showReport() {
  const avg = bpmHist.length>0 ? Math.round(bpmHist.reduce((a,b)=>a+b)/bpmHist.length) : 0;
  const highCount = sData.filter(v=>v===4).length;
  const highPct   = sData.length>0 ? Math.round(highCount/sData.length*100) : 0;
  const elapsed   = Math.floor((Date.now()-sessionStartTime)/1000);
  const hrv = parseInt(document.getElementById('hrvVal').textContent)||0;

  let grade, gradeColor;
  if (highPct < 10 && avg < 85)       { grade='A+'; gradeColor='#00ff88'; }
  else if (highPct < 20 && avg < 95)  { grade='A';  gradeColor='#00ff88'; }
  else if (highPct < 35 && avg < 105) { grade='B';  gradeColor='#00aaff'; }
  else if (highPct < 50)              { grade='C';  gradeColor='#ffaa00'; }
  else if (highPct < 70)              { grade='D';  gradeColor='#ff6633'; }
  else                                { grade='F';  gradeColor='#ff3355'; }

  document.getElementById('reportGrade').textContent = grade;
  document.getElementById('reportGrade').style.color  = gradeColor;

  const mm=String(Math.floor(elapsed/60)).padStart(2,'0'), ss=String(elapsed%60).padStart(2,'0');
  const rows = [
    ['Session Duration', mm+':'+ss],
    ['Average BPM', avg||'--'],
    ['Peak BPM', peakBPM||'--'],
    ['Min BPM', minBPM<999?minBPM:'--'],
    ['HRV Estimate', hrv?hrv+'ms':'--'],
    ['High Stress Time', highPct+'%'],
    ['Total Readings', sData.length],
  ];

  document.getElementById('reportRows').innerHTML = rows.map(([l,v])=>
    `<div class="report-row"><span class="report-row-label">${l}</span><span class="report-row-val">${v}</span></div>`
  ).join('');

  document.getElementById('reportOverlay').classList.add('visible');
}

document.getElementById('reportBtn').addEventListener('click', showReport);
document.getElementById('reportClose').addEventListener('click',()=>document.getElementById('reportOverlay').classList.remove('visible'));

// ── Snapshot ──────────────────────────────────────────
document.getElementById('snapshotBtn').addEventListener('click', ()=>{
  // Draw everything onto an offscreen canvas
  const w=800, h=320;
  const snap = document.createElement('canvas');
  snap.width=w; snap.height=h;
  const sc = snap.getContext('2d');

  // Background
  sc.fillStyle='#080c0f'; sc.fillRect(0,0,w,h);

  // Title
  sc.fillStyle=getECGColor(); sc.font='bold 14px Share Tech Mono';
  sc.fillText('STRESS MONITOR — SNAPSHOT', 20, 30);
  sc.fillStyle='#4a6a4a'; sc.font='10px Share Tech Mono';
  sc.fillText(new Date().toLocaleString(), 20, 48);

  // Stats
  const stats = [
    ['BPM', currentBPM>0?currentBPM:'--'],
    ['STRESS', lastStress||'NO DATA'],
    ['HRV', document.getElementById('hrvVal').textContent+'ms'],
    ['TEMP', document.getElementById('tempVal').textContent+'°C'],
    ['HUM', document.getElementById('humVal').textContent+'%'],
    ['PEAK', peakBPM||'--'],
  ];
  sc.fillStyle=getECGColor(); sc.font='bold 12px Share Tech Mono';
  stats.forEach(([l,v],i)=>{
    const x=20+(i%3)*260, y=i<3?90:140;
    sc.fillStyle='#4a6a4a'; sc.font='10px Share Tech Mono'; sc.fillText(l, x, y-14);
    sc.fillStyle=getECGColor(); sc.font='bold 24px Share Tech Mono'; sc.fillText(v, x, y+6);
  });

  // ECG mini render
  sc.fillStyle='#060c06'; sc.fillRect(20, 168, w-40, 120);
  sc.strokeStyle='#1a2a1a'; sc.lineWidth=1;
  for(let gx=0;gx<w-40;gx+=40){sc.beginPath();sc.moveTo(20+gx,168);sc.lineTo(20+gx,288);sc.stroke();}
  for(let gy=0;gy<120;gy+=20){sc.beginPath();sc.moveTo(20,168+gy);sc.lineTo(w-20,168+gy);sc.stroke();}

  const mid=228, amp=48, xStep=(w-40)/ECG_HIST;
  sc.beginPath(); sc.strokeStyle=getECGColor(); sc.lineWidth=2; sc.lineJoin='round';
  for(let i=0;i<ECG_HIST;i++){
    const b=(writeHead+i)%ECG_HIST, x=20+i*xStep, y=mid-ecgData[b]*amp;
    if(i===0)sc.moveTo(x,y);else sc.lineTo(x,y);
  }
  sc.stroke();

  // Download
  const link=document.createElement('a');
  link.download='stress_monitor_'+Date.now()+'.png';
  link.href=snap.toDataURL();
  link.click();
  showToast('SNAPSHOT SAVED');
});

// ── Alert ─────────────────────────────────────────────
let alertDismissed=false;
function triggerAlert() {
  if(alertDismissed) return;
  document.getElementById('alertOverlay').classList.add('visible');
  try{ const ac=new(window.AudioContext||window.webkitAudioContext)(),o=ac.createOscillator(),g=ac.createGain();o.connect(g);g.connect(ac.destination);o.type='sine';o.frequency.value=880;g.gain.setValueAtTime(.3,ac.currentTime);g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+.8);o.start();o.stop(ac.currentTime+.8); }catch(e){}
}
document.getElementById('alertDismiss').addEventListener('click',()=>{
  document.getElementById('alertOverlay').classList.remove('visible');
  alertDismissed=true; openBreathing();
  setTimeout(()=>alertDismissed=false, 60000);
});

// ── Breathing ─────────────────────────────────────────
const phases=[{name:'INHALE',cls:'inhale',duration:4},{name:'HOLD',cls:'hold',duration:4},{name:'EXHALE',cls:'exhale',duration:4},{name:'HOLD',cls:'hold',duration:4}];
let breathPhase=0,breathCount=0,breathInterval=null;
function openBreathing(){
  document.getElementById('breathingPanel').classList.add('visible');
  breathPhase=0; runBreath();
}
function runBreath(){
  clearInterval(breathInterval);
  const p=phases[breathPhase];
  document.getElementById('breathInstruction').textContent=p.name;
  const c=document.getElementById('breathCircle'); c.className='breath-circle'; void c.offsetWidth; c.className='breath-circle '+p.cls;
  breathCount=p.duration; document.getElementById('breathCount').textContent=breathCount;
  breathInterval=setInterval(()=>{ breathCount--; document.getElementById('breathCount').textContent=breathCount; if(breathCount<=0){breathPhase=(breathPhase+1)%phases.length;runBreath();} },1000);
}
document.getElementById('breathBtn').addEventListener('click',openBreathing);
document.getElementById('breathClose').addEventListener('click',()=>{ document.getElementById('breathingPanel').classList.remove('visible'); clearInterval(breathInterval); });

// ── Panic button ──────────────────────────────────────
let panicActive = false;
document.getElementById('panicBtn').addEventListener('click',()=>{
  panicActive = !panicActive;
  document.getElementById('panicOverlay').classList.toggle('active', panicActive);
  document.getElementById('panicBtn').classList.toggle('active', panicActive);
  if (panicActive) { openBreathing(); showToast('CALM MODE ACTIVATED — BREATHE'); }
  else { showToast('CALM MODE OFF'); }
});

// ── Ambient mode ──────────────────────────────────────
document.getElementById('ambientBtn').addEventListener('click',()=>{
  document.getElementById('ambientOverlay').classList.add('active');
  setTimeout(resizeCanvas, 100);
});
document.getElementById('ambientExit').addEventListener('click',()=>
  document.getElementById('ambientOverlay').classList.remove('active'));

// ── Notes ─────────────────────────────────────────────
let notes=[],lastStress='NO DATA';
function renderNotes(){
  const list=document.getElementById('notesList'),empty=document.getElementById('notesEmpty'),badge=document.getElementById('notesBadge');
  if(notes.length===0){empty.style.display='block';badge.style.display='none';}
  else{empty.style.display='none';badge.style.display='flex';badge.textContent=notes.length;}
  list.querySelectorAll('.note-item').forEach(n=>n.remove());
  notes.slice().reverse().forEach((n,i)=>{
    const div=document.createElement('div');div.className='note-item';
    div.innerHTML=`<div><div class="note-meta">${n.time} | BPM:${n.bpm} | ${n.stress}</div><div class="note-text">${n.text}</div></div><button class="note-del" data-i="${notes.length-1-i}">✕</button>`;
    list.appendChild(div);
  });
  list.querySelectorAll('.note-del').forEach(btn=>btn.addEventListener('click',()=>{notes.splice(+btn.dataset.i,1);renderNotes();}));
}
function addNote(){
  const inp=document.getElementById('notesInput'),text=inp.value.trim();
  if(!text) return;
  notes.push({text,time:new Date().toLocaleTimeString(),bpm:currentBPM||'--',stress:lastStress});
  inp.value=''; renderNotes();
}
document.getElementById('notesAdd').addEventListener('click',addNote);
document.getElementById('notesInput').addEventListener('keydown',e=>{if(e.key==='Enter')addNote();});
document.getElementById('notesBtn').addEventListener('click',()=>document.getElementById('notesOverlay').classList.add('visible'));
document.getElementById('notesClose').addEventListener('click',()=>document.getElementById('notesOverlay').classList.remove('visible'));
renderNotes();

// ── Countdown ─────────────────────────────────────────
let cdLeft=0,cdActive=false,cdInterval=null;
function fmtTime(s){return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');}
function updateCD(){const el=document.getElementById('countdownDisplay');el.textContent=cdLeft>0?fmtTime(cdLeft):'--:--';el.className='countdown-display'+(cdLeft>0&&cdLeft<=10?' warning':'');}
document.getElementById('countdownStart').addEventListener('click',()=>{
  if(cdActive){clearInterval(cdInterval);cdActive=false;document.getElementById('countdownStart').textContent='▶';return;}
  const mins=parseInt(document.getElementById('countdownInput').value)||5;
  cdLeft=mins*60;updateCD();cdActive=true;document.getElementById('countdownStart').textContent='■';
  cdInterval=setInterval(()=>{ cdLeft--;updateCD();if(cdLeft<=0){clearInterval(cdInterval);cdActive=false;document.getElementById('countdownStart').textContent='▶';showToast('⏱ SESSION COMPLETE');} },1000);
});
document.getElementById('countdownReset').addEventListener('click',()=>{clearInterval(cdInterval);cdActive=false;cdLeft=0;updateCD();document.getElementById('countdownStart').textContent='▶';});

// ── Toast ─────────────────────────────────────────────
let toastTimeout=null;
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastTimeout);toastTimeout=setTimeout(()=>t.classList.remove('show'),2200);}

// ── Theme ─────────────────────────────────────────────
let isDark=true;
function toggleTheme(){isDark=!isDark;document.documentElement.setAttribute('data-theme',isDark?'dark':'light');document.getElementById('themeBtn').textContent=isDark?'☀ LIGHT':'☾ DARK';showToast(isDark?'DARK MODE':'LIGHT MODE');}
document.getElementById('themeBtn').addEventListener('click',toggleTheme);

// ── Fullscreen ────────────────────────────────────────
function toggleFullscreen(){if(!document.fullscreenElement){document.documentElement.requestFullscreen();document.getElementById('fullscreenBtn').textContent='⛶ EXIT';}else{document.exitFullscreen();document.getElementById('fullscreenBtn').textContent='⛶ FULL';}}
document.getElementById('fullscreenBtn').addEventListener('click',toggleFullscreen);

// ── Keyboard shortcuts ────────────────────────────────
document.addEventListener('keydown',e=>{
  const tag=document.activeElement.tagName;
  if(tag==='INPUT'||tag==='TEXTAREA') return;
  switch(e.key.toUpperCase()){
    case 'F': toggleFullscreen(); break;
    case 'B': openBreathing(); showToast('BREATHING GUIDE'); break;
    case 'N': document.getElementById('notesOverlay').classList.add('visible'); break;
    case 'T': toggleTheme(); break;
    case 'A': document.getElementById('ambientBtn').click(); break;
    case 'P': document.getElementById('panicBtn').click(); break;
    case 'S': document.getElementById('soundBtn').click(); break;
    case 'R': showReport(); break;
    case '?': document.getElementById('kbPanel').classList.toggle('visible'); break;
    case 'ESCAPE':
      ['alertOverlay','notesOverlay','kbPanel','reportOverlay'].forEach(id=>document.getElementById(id).classList.remove('visible'));
      document.getElementById('ambientOverlay').classList.remove('active');
      if(panicActive){panicActive=false;document.getElementById('panicOverlay').classList.remove('active');document.getElementById('panicBtn').classList.remove('active');}
      break;
  }
});
document.getElementById('kbBtn').addEventListener('click',()=>document.getElementById('kbPanel').classList.toggle('visible'));
document.getElementById('kbClose').addEventListener('click',()=>document.getElementById('kbPanel').classList.remove('visible'));

// ── Clock + Session ───────────────────────────────────
let sessionStartTime=Date.now();
function updateClock(){
  document.getElementById('liveClock').textContent=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const e=Math.floor((Date.now()-sessionStartTime)/1000);
  document.getElementById('sessionTimer').textContent=String(Math.floor(e/60)).padStart(2,'0')+':'+String(e%60).padStart(2,'0');
}
setInterval(updateClock,1000);updateClock();

// Push charts + heatmap every second
setInterval(()=>{if(currentBPM>0)pushCharts(currentBPM,lastStress);updateTrend(lastStress);},1000);

// ── Stress descriptions ───────────────────────────────
const stressDesc={'NO DATA':'Place finger on sensor','LOW':'Relaxed — BPM below 75','NORMAL':'Normal range — 75 to 90 BPM','MODERATE':'Elevated — 90 to 110 BPM','HIGH':'High stress — BPM above 110'};

// ── Socket Data ───────────────────────────────────────
socket.on('sensor_data',data=>{
  currentBPM=data.bpm||0;
  const stress=data.stress||'NO DATA';
  lastStress=stress;

  // Auto stress theme + ECG color
  document.documentElement.setAttribute('data-stress',stress.replace(' ','-'));

  // BPM
  const bpmEl=document.getElementById('bpmVal');
  if(currentBPM>0){
    animateValue(bpmEl,prevBPM,currentBPM);
    prevBPM=currentBPM;
    const pct=Math.min(((currentBPM-40)/140)*100,100);
    document.getElementById('bpmFill').style.width=pct+'%';
    updateStats(currentBPM);
  } else {bpmEl.textContent='--';prevBPM=0;document.getElementById('bpmFill').style.width='0%';}

  // HRV
  const hrv=estimateHRV(currentBPM);
  updateHRVGauge(hrv);

  // No signal
  const ns=document.getElementById('noSignal');
  if(currentBPM>0)ns.classList.add('hidden');else ns.classList.remove('hidden');

  // Ambient display
  document.getElementById('ambientBpm').textContent=currentBPM>0?currentBPM+' BPM':'--';
  document.getElementById('ambientBpm').style.color=getComputedStyle(document.documentElement).getPropertyValue('--ecg-color');
  document.getElementById('ambientStress').textContent=stress;

  // Alert
  if(stress==='HIGH'&&lastStress!=='HIGH')triggerAlert();
  if(stress!=='HIGH')alertDismissed=false;

  // Stress badge
  const key=stress.replace(' ','-');
  document.getElementById('stressBadge').textContent=stress;
  document.getElementById('stressBadge').className='stress-badge stress-'+key;
  document.getElementById('stressDesc').textContent=stressDesc[stress]||'';

  // Temp
  const tEl=document.getElementById('tempVal'),tSub=document.getElementById('tempSub');
  if(data.temp>0){tEl.textContent=data.temp.toFixed(1);tEl.style.color=data.temp>30?'var(--amber)':'var(--green)';tSub.textContent=data.temp>30?'ELEVATED':'NORMAL';}
  else{tEl.textContent='--';tSub.textContent='--';}

  // Humidity
  const hEl=document.getElementById('humVal'),hSub=document.getElementById('humSub');
  if(data.hum>0){hEl.textContent=data.hum;hEl.style.color=data.hum>70?'var(--amber)':'var(--green)';hSub.textContent=data.hum>70?'HIGH':'NORMAL';}
  else{hEl.textContent='--';hSub.textContent='--';}

  // Connection
  const dot=document.getElementById('statusDot'),txt=document.getElementById('statusText');
  if(data.connected){dot.className='dot online';txt.textContent='CONNECTED';}
  else{dot.className='dot offline';txt.textContent='DISCONNECTED';}

  document.getElementById('timestamp').textContent='LAST UPDATE: '+new Date().toLocaleTimeString();
});

socket.on('disconnect',()=>{
  document.getElementById('statusDot').className='dot offline';
  document.getElementById('statusText').textContent='DISCONNECTED';
});
</script>
