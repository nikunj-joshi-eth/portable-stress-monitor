<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Stress Monitor</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.6.1/socket.io.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;800&display=swap" rel="stylesheet"/>
<style>
/* ── VARIABLES ───────────────────────────────────── */
:root {
  --bg:         #080c0f;
  --panel:      #0d1318;
  --border:     #1a2a1a;
  --green:      #00ff88;
  --green-dim:  #00aa55;
  --green-glow: #00ff8844;
  --amber:      #ffaa00;
  --red:        #ff3355;
  --blue:       #00aaff;
  --text:       #c8e6c8;
  --text-dim:   #4a6a4a;
  --mono:       'Share Tech Mono', monospace;
  --sans:       'Exo 2', sans-serif;
  --header-bg:  #0a0f0a;
  --ecg-bg:     #060c06;
  --accent:     #00ff88;
  --accent-glow:#00ff8844;
  --ecg-color:  #00ff88;
}
[data-theme="light"] {
  --bg:        #f0f4f0; --panel:#fff; --border:#c8dac8;
  --green:     #00884a; --green-dim:#006633; --green-glow:#00884422;
  --amber:     #cc8800; --red:#cc1133; --blue:#0066cc;
  --text:      #1a2a1a; --text-dim:#6a8a6a;
  --header-bg: #e0ece0; --ecg-bg:#f8fdf8;
}
[data-stress="HIGH"]     { --accent:#ff3355; --accent-glow:#ff335533; --ecg-color:#ff3355; }
[data-stress="MODERATE"] { --accent:#ffaa00; --accent-glow:#ffaa0033; --ecg-color:#ffaa00; }
[data-stress="NORMAL"]   { --accent:#00ff88; --accent-glow:#00ff8844; --ecg-color:#00ff88; }
[data-stress="LOW"]      { --accent:#00aaff; --accent-glow:#00aaff33; --ecg-color:#00aaff; }

*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;overflow-x:hidden;transition:background .5s,color .5s;}
[data-theme="dark"] body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,#00000018 2px,#00000018 4px);pointer-events:none;z-index:1;}

/* ── PARTICLE CANVAS ────────────────────────────── */
#particleCanvas{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.35;}

/* ── RIPPLE ─────────────────────────────────────── */
.ripple{position:fixed;border-radius:50%;border:2px solid var(--accent);pointer-events:none;z-index:2;transform:translate(-50%,-50%) scale(0);animation:ripple-out 1s ease-out forwards;}
@keyframes ripple-out{0%{transform:translate(-50%,-50%) scale(0);opacity:.8;}100%{transform:translate(-50%,-50%) scale(4);opacity:0;}}

/* ── TOAST ───────────────────────────────────────── */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:10px 20px;font-family:var(--mono);font-size:.7rem;letter-spacing:.12em;color:var(--accent);z-index:300;opacity:0;transition:all .3s;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── PANIC OVERLAY ───────────────────────────────── */
.panic-overlay{position:fixed;inset:0;background:#00000099;z-index:190;opacity:0;pointer-events:none;transition:opacity .5s;backdrop-filter:blur(8px);}
.panic-overlay.active{opacity:1;pointer-events:all;}

/* ── AMBIENT MODE ────────────────────────────────── */
.ambient-overlay{display:none;position:fixed;inset:0;background:#000;z-index:160;flex-direction:column;align-items:center;justify-content:center;}
.ambient-overlay.active{display:flex;}
.ambient-ecg-wrap{width:100vw;height:60vh;position:relative;}
#ambientEcg{width:100%;height:100%;}
.ambient-bpm{font-family:var(--mono);font-size:6rem;color:var(--ecg-color);text-shadow:0 0 40px var(--accent-glow);margin-top:20px;transition:color .5s;}
.ambient-stress{font-family:var(--mono);font-size:1.2rem;color:var(--text-dim);letter-spacing:.3em;margin-top:8px;}
.ambient-exit{position:absolute;top:20px;right:24px;background:none;border:1px solid #333;color:#555;font-family:var(--mono);font-size:.65rem;letter-spacing:.12em;padding:6px 12px;border-radius:3px;cursor:pointer;}
.ambient-exit:hover{border-color:#888;color:#aaa;}

/* ── HEADER ──────────────────────────────────────── */
header{display:flex;justify-content:space-between;align-items:center;padding:12px 24px;border-bottom:1px solid var(--border);background:var(--header-bg);position:sticky;top:0;z-index:50;transition:background .4s;flex-wrap:wrap;gap:10px;}
.header-left{display:flex;align-items:center;gap:14px;}
.heart-icon{font-size:1.4rem;color:var(--accent);transition:color .5s;filter:drop-shadow(0 0 6px var(--accent-glow));}
@keyframes heartbeat{0%{transform:scale(1)}14%{transform:scale(1.3)}28%{transform:scale(1)}42%{transform:scale(1.15)}70%{transform:scale(1)}100%{transform:scale(1)}}
.header-title h1{font-family:var(--mono);font-size:.95rem;color:var(--accent);letter-spacing:.15em;transition:color .5s;}
.header-title p{font-size:.6rem;color:var(--text-dim);letter-spacing:.1em;margin-top:2px;}
.header-spark{display:flex;flex-direction:column;align-items:center;gap:2px;}
.spark-label{font-family:var(--mono);font-size:.55rem;color:var(--text-dim);letter-spacing:.1em;}
.header-right{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.header-clock{font-family:var(--mono);font-size:.75rem;color:var(--accent);letter-spacing:.1em;text-align:right;transition:color .5s;}
.header-clock span{display:block;font-size:.58rem;color:var(--text-dim);margin-top:2px;}
.icon-btn{background:none;border:1px solid var(--border);color:var(--text-dim);font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;padding:5px 9px;border-radius:3px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.icon-btn:hover{border-color:var(--accent);color:var(--accent);box-shadow:0 0 8px var(--accent-glow);}
.icon-btn.active{border-color:var(--accent);color:var(--accent);background:var(--accent-glow);}
.panic-btn{border-color:var(--red)!important;color:var(--red)!important;}
.panic-btn:hover{background:#ff335522!important;box-shadow:0 0 12px #ff335544!important;}
.status-dot{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:.7rem;letter-spacing:.1em;}
.dot{width:8px;height:8px;border-radius:50%;background:var(--text-dim);transition:background .3s;}
.dot.online{background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse-dot 2s infinite;}
.dot.offline{background:var(--red);}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}

/* ── GRID ────────────────────────────────────────── */
.grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;padding:16px 20px;max-width:1400px;margin:0 auto;position:relative;z-index:5;}
.ecg-panel,.history-panel,.stress-chart-panel,.heatmap-panel{grid-column:1/-1;}

/* ── PANEL ───────────────────────────────────────── */
.panel{background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:16px 20px;position:relative;overflow:hidden;transition:background .4s,border-color .4s;}
[data-theme="dark"] .panel::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.25;transition:background .5s;}
.panel-label{font-family:var(--mono);font-size:.58rem;letter-spacing:.2em;color:var(--text-dim);text-transform:uppercase;margin-bottom:10px;}

/* ── BPM ─────────────────────────────────────────── */
.bpm-value{font-family:var(--mono);font-size:3.8rem;color:var(--accent);text-shadow:0 0 20px var(--accent-glow);line-height:1;transition:color .4s,text-shadow .4s;}
.bpm-unit{font-family:var(--mono);font-size:.7rem;color:var(--green-dim);letter-spacing:.15em;margin-top:4px;}
.bpm-meta{display:flex;gap:16px;margin-top:10px;}
.bpm-meta-item{font-family:var(--mono);font-size:.6rem;color:var(--text-dim);}
.bpm-meta-item strong{color:var(--accent);font-size:.85rem;display:block;transition:color .4s;}
.bpm-bar{margin-top:10px;height:3px;background:var(--border);border-radius:2px;overflow:hidden;}
.bpm-fill{height:100%;background:var(--accent);box-shadow:0 0 8px var(--accent);border-radius:2px;transition:width .8s ease,background .5s;}
.bpm-range{display:flex;justify-content:space-between;margin-top:4px;font-family:var(--mono);font-size:.55rem;color:var(--text-dim);}

/* ── STRESS ──────────────────────────────────────── */
.stress-badge{display:inline-block;font-family:var(--mono);font-size:1.4rem;letter-spacing:.12em;padding:8px 14px;border-radius:3px;transition:all .5s;margin-top:4px;}
.stress-LOW     {color:var(--blue); border:1px solid var(--blue); background:#00aaff11;text-shadow:0 0 10px var(--blue);}
.stress-NORMAL  {color:var(--green);border:1px solid var(--green);background:var(--green-glow);text-shadow:0 0 10px var(--green);}
.stress-MODERATE{color:var(--amber);border:1px solid var(--amber);background:#ffaa0011;text-shadow:0 0 10px var(--amber);}
.stress-HIGH    {color:var(--red);  border:1px solid var(--red);  background:#ff335511;text-shadow:0 0 10px var(--red);animation:stress-flash .8s infinite;}
.stress-NO-DATA {color:var(--text-dim);border:1px solid var(--border);background:transparent;}
@keyframes stress-flash{0%,100%{opacity:1}50%{opacity:.55}}
.stress-desc{font-size:.62rem;color:var(--text-dim);margin-top:8px;font-family:var(--mono);letter-spacing:.08em;min-height:1.2em;}

/* Trend arrow */
.trend-row{display:flex;align-items:center;gap:8px;margin-top:10px;}
.trend-arrow{font-size:1.4rem;transition:all .5s;}
.trend-label{font-family:var(--mono);font-size:.65rem;color:var(--text-dim);letter-spacing:.1em;}

/* ── HRV GAUGE ───────────────────────────────────── */
.hrv-wrap{display:flex;flex-direction:column;align-items:center;margin-top:4px;}
.hrv-gauge{position:relative;width:100px;height:55px;overflow:hidden;}
.hrv-gauge svg{width:100%;height:auto;}
.hrv-val{font-family:var(--mono);font-size:1.6rem;color:var(--accent);text-align:center;margin-top:4px;transition:color .4s;}
.hrv-unit{font-family:var(--mono);font-size:.6rem;color:var(--text-dim);text-align:center;letter-spacing:.1em;}
.hrv-desc{font-family:var(--mono);font-size:.58rem;color:var(--text-dim);text-align:center;margin-top:4px;letter-spacing:.08em;}

/* ── ENV ─────────────────────────────────────────── */
.env-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:4px;}
.env-val{font-family:var(--mono);font-size:1.9rem;color:var(--green);text-shadow:0 0 12px var(--green-glow);line-height:1;transition:color .4s;}
.env-unit{font-family:var(--mono);font-size:.62rem;color:var(--green-dim);letter-spacing:.1em;}
.env-sub{font-size:.58rem;color:var(--text-dim);font-family:var(--mono);margin-top:3px;}

/* ── ECG ─────────────────────────────────────────── */
.ecg-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.ecg-badge{font-family:var(--mono);font-size:.58rem;color:var(--accent);background:var(--accent-glow);border:1px solid var(--green-dim);padding:3px 8px;border-radius:2px;letter-spacing:.12em;transition:color .5s,background .5s;}
.ecg-wrapper{position:relative;background:var(--ecg-bg);border:1px solid var(--border);border-radius:3px;overflow:hidden;transition:background .4s;}
.ecg-wrapper::before{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:40px 20px;pointer-events:none;opacity:.4;}
canvas#ecg{display:block;width:100%;height:120px;position:relative;z-index:1;}
.sweep{position:absolute;top:0;bottom:0;width:3px;background:linear-gradient(90deg,transparent,var(--accent-glow),transparent);pointer-events:none;z-index:2;transition:left .1s linear;}
.no-signal{position:absolute;inset:0;background:#080c0faa;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:.72rem;color:var(--text-dim);letter-spacing:.2em;z-index:10;backdrop-filter:blur(2px);transition:opacity .5s;}
.no-signal.hidden{opacity:0;pointer-events:none;}

/* ── HEATMAP ─────────────────────────────────────── */
.heatmap-grid{display:flex;flex-wrap:wrap;gap:3px;margin-top:8px;}
.heatmap-cell{width:14px;height:14px;border-radius:2px;background:#1a2a1a;transition:background .5s;cursor:default;position:relative;}
.heatmap-cell:hover::after{content:attr(data-tip);position:absolute;bottom:18px;left:50%;transform:translateX(-50%);background:var(--panel);border:1px solid var(--border);padding:3px 6px;font-family:var(--mono);font-size:.55rem;color:var(--text);border-radius:2px;white-space:nowrap;z-index:10;}
.heatmap-legend{display:flex;align-items:center;gap:6px;margin-top:8px;}
.heatmap-legend-bar{display:flex;gap:2px;}
.heatmap-legend-cell{width:10px;height:10px;border-radius:1px;}
.heatmap-legend span{font-family:var(--mono);font-size:.55rem;color:var(--text-dim);}

/* ── REPORT CARD ─────────────────────────────────── */
.report-overlay{position:fixed;inset:0;background:#00000099;display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(6px);}
.report-overlay.visible{opacity:1;pointer-events:all;}
.report-box{background:var(--panel);border:1px solid var(--border);border-radius:8px;padding:36px 44px;width:520px;max-width:95vw;box-shadow:0 20px 60px #00000066;}
.report-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;}
.report-header h2{font-family:var(--mono);font-size:1rem;color:var(--accent);letter-spacing:.2em;}
.report-grade{font-family:var(--mono);font-size:3.5rem;font-weight:800;line-height:1;}
.report-rows{display:flex;flex-direction:column;gap:10px;margin-bottom:24px;}
.report-row{display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:.7rem;padding:8px 0;border-bottom:1px solid var(--border);}
.report-row-label{color:var(--text-dim);}
.report-row-val{color:var(--accent);}
.report-close{background:none;border:1px solid var(--border);color:var(--text-dim);font-family:var(--mono);font-size:.65rem;letter-spacing:.12em;padding:9px 20px;border-radius:3px;cursor:pointer;width:100%;transition:all .2s;}
.report-close:hover{border-color:var(--accent);color:var(--accent);}

/* ── CHARTS ──────────────────────────────────────── */
.chart-wrapper{position:relative;height:140px;}

/* ── COUNTDOWN ───────────────────────────────────── */
.countdown-row{display:flex;align-items:center;gap:10px;margin-top:10px;flex-wrap:wrap;}
.countdown-display{font-family:var(--mono);font-size:1.4rem;color:var(--accent);letter-spacing:.1em;min-width:70px;transition:color .4s;}
.countdown-display.warning{color:var(--red);animation:stress-flash .5s infinite;}
.countdown-input{background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:.7rem;padding:5px 8px;border-radius:3px;width:60px;letter-spacing:.1em;}
.countdown-input:focus{outline:none;border-color:var(--accent);}

/* ── NOTES ───────────────────────────────────────── */
.notes-overlay{position:fixed;inset:0;background:#00000088;display:flex;align-items:center;justify-content:center;z-index:180;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(4px);}
.notes-overlay.visible{opacity:1;pointer-events:all;}
.notes-box{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:28px 32px;width:560px;max-width:95vw;}
.notes-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.notes-header h3{font-family:var(--mono);font-size:.8rem;color:var(--accent);letter-spacing:.15em;}
.notes-close{background:none;border:none;color:var(--text-dim);font-size:1rem;cursor:pointer;}
.notes-entry{display:flex;gap:8px;margin-bottom:12px;}
.notes-input{flex:1;background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:.72rem;padding:8px 12px;border-radius:3px;}
.notes-input:focus{outline:none;border-color:var(--accent);}
.notes-add{background:none;border:1px solid var(--accent);color:var(--accent);font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;padding:8px 14px;border-radius:3px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.notes-add:hover{background:var(--accent);color:var(--bg);}
.notes-list{max-height:260px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;}
.note-item{background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:8px 12px;display:flex;justify-content:space-between;align-items:flex-start;gap:10px;}
.note-meta{font-family:var(--mono);font-size:.58rem;color:var(--text-dim);margin-bottom:3px;}
.note-text{font-family:var(--mono);font-size:.68rem;color:var(--text);letter-spacing:.05em;line-height:1.5;}
.note-del{background:none;border:none;color:var(--text-dim);font-size:.7rem;cursor:pointer;}
.note-del:hover{color:var(--red);}
.notes-empty{font-family:var(--mono);font-size:.65rem;color:var(--text-dim);text-align:center;padding:20px;letter-spacing:.1em;}
.notes-badge{position:absolute;top:-5px;right:-5px;background:var(--accent);color:var(--bg);font-family:var(--mono);font-size:.55rem;width:16px;height:16px;border-radius:50%;display:none;align-items:center;justify-content:center;}
.notes-btn-wrap{position:relative;display:inline-block;}

/* ── ALERT ───────────────────────────────────────── */
.alert-overlay{position:fixed;inset:0;background:#00000088;display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(4px);}
.alert-overlay.visible{opacity:1;pointer-events:all;}
.alert-box{background:var(--panel);border:2px solid var(--red);border-radius:6px;padding:32px 40px;text-align:center;box-shadow:0 0 40px #ff335544;animation:alert-pulse .8s infinite;max-width:400px;width:90%;}
@keyframes alert-pulse{0%,100%{box-shadow:0 0 40px #ff335544}50%{box-shadow:0 0 80px #ff335588}}
.alert-box h2{font-family:var(--mono);font-size:1.2rem;color:var(--red);letter-spacing:.2em;margin-bottom:10px;}
.alert-box p{font-family:var(--mono);font-size:.7rem;color:var(--text-dim);letter-spacing:.08em;line-height:1.6;margin-bottom:22px;}
.alert-btn{background:none;border:1px solid var(--red);color:var(--red);font-family:var(--mono);font-size:.7rem;letter-spacing:.12em;padding:9px 20px;border-radius:3px;cursor:pointer;transition:all .2s;}
.alert-btn:hover{background:var(--red);color:#fff;}

/* ── BREATHING ───────────────────────────────────── */
.breathing-panel{display:none;position:fixed;bottom:20px;right:20px;z-index:195;background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:18px 22px;width:190px;text-align:center;box-shadow:0 8px 32px #00000044;}
.breathing-panel.visible{display:block;}
.breathing-title{font-family:var(--mono);font-size:.58rem;color:var(--text-dim);letter-spacing:.2em;margin-bottom:12px;}
.breath-circle{width:72px;height:72px;border-radius:50%;border:2px solid var(--blue);margin:0 auto 10px;box-shadow:0 0 14px #00aaff44;}
.breath-circle.inhale{animation:breath-in  4s ease-in-out forwards;}
.breath-circle.hold  {animation:breath-hold 4s ease forwards;}
.breath-circle.exhale{animation:breath-out  4s ease-in-out forwards;}
@keyframes breath-in  {0%{transform:scale(.7);opacity:.5}100%{transform:scale(1.3);opacity:1}}
@keyframes breath-hold{0%,100%{transform:scale(1.3);opacity:1}}
@keyframes breath-out {0%{transform:scale(1.3);opacity:1}100%{transform:scale(.7);opacity:.5}}
.breath-instruction{font-family:var(--mono);font-size:.7rem;color:var(--blue);letter-spacing:.15em;text-transform:uppercase;}
.breath-count{font-family:var(--mono);font-size:1.3rem;color:var(--text);margin-top:3px;}
.breath-close{margin-top:10px;background:none;border:none;color:var(--text-dim);font-family:var(--mono);font-size:.58rem;letter-spacing:.1em;cursor:pointer;}

/* ── KB PANEL ────────────────────────────────────── */
.kb-panel{display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:250;background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:28px 36px;min-width:320px;box-shadow:0 16px 48px #00000066;}
.kb-panel.visible{display:block;}
.kb-panel h3{font-family:var(--mono);font-size:.8rem;color:var(--accent);letter-spacing:.2em;margin-bottom:16px;}
.kb-row{display:flex;justify-content:space-between;gap:20px;margin-bottom:10px;font-family:var(--mono);font-size:.68rem;}
.kb-key{background:var(--bg);border:1px solid var(--border);padding:3px 8px;border-radius:3px;color:var(--accent);letter-spacing:.1em;}
.kb-desc{color:var(--text-dim);}
.kb-close{margin-top:16px;background:none;border:1px solid var(--border);color:var(--text-dim);font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;padding:7px 14px;border-radius:3px;cursor:pointer;width:100%;transition:all .2s;}
.kb-close:hover{border-color:var(--accent);color:var(--accent);}

.timestamp{font-family:var(--mono);font-size:.58rem;color:var(--text-dim);text-align:right;padding:6px 20px 16px;letter-spacing:.1em;position:relative;z-index:5;}
